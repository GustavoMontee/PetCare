@model PetCare.Models.Servico

<h1>Excluir Serviço</h1>

<h3>Deseja realmente excluir?</h3>

<div>
    <hr />

    <dl class="row">
        <dt class="col-sm-2">Nome</dt>
        <dd class="col-sm-10">@Model.Nome</dd>

        <dt class="col-sm-2">Valor</dt>
        <dd class="col-sm-10">R$ @Model.Valor</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />

        <button type="submit"
                class="btn btn-danger">
            Excluir
        </button>

        <a asp-action="Index"
           class="btn btn-secondary">
            Voltar
        </a>
    </form>
</div>