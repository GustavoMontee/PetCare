<div class="container mt-4">

    <div class="card shadow">
        <div class="card-body text-center">

            <h2 class="mb-3">
                <i class="bi bi-heart-pulse text-primary"></i> Bem-vindo ao PetCare
            </h2>

            <p class="text-muted">
                Sistema de gerenciamento para PetShop.
                Cadastre clientes, gerencie pets e organize atendimentos.
            </p>

        </div>
    </div>

    <div class="row mt-4">

        <!-- CLIENTES -->
        <div class="col-md-3">
            <div class="card shadow h-100">
                <div class="card-body text-center">

                    <i class="bi bi-people text-primary" style="font-size:40px"></i>

                    <h5 class="mt-3">Clientes</h5>

                    <p class="text-muted">
                        Gerencie os clientes cadastrados no sistema.
                    </p>

                    <a asp-controller="Clientes"
                       asp-action="Index"
                       class="btn btn-primary">
                        Abrir
                    </a>

                </div>
            </div>
        </div>

        <!-- PETS -->
        <div class="col-md-3">
            <div class="card shadow h-100">
                <div class="card-body text-center">

                    <i class="bi bi-heart text-primary" style="font-size:40px"></i>

                    <h5 class="mt-3">Pets</h5>

                    <p class="text-muted">
                        Gerencie os pets vinculados aos clientes.
                    </p>

                    <a asp-controller="Pet"
                       asp-action="Index"
                       class="btn btn-primary">
                        Abrir
                    </a>

                </div>
            </div>
        </div>

        <!-- USUÁRIOS -->
        <div class="col-md-3">
            <div class="card shadow h-100">
                <div class="card-body text-center">

                    <i class="bi bi-person-gear text-primary" style="font-size:40px"></i>

                    <h5 class="mt-3">Usuários</h5>

                    <p class="text-muted">
                        Gerencie os usuários com acesso ao sistema.
                    </p>

                    <a asp-controller="UsuariosSistema"
                       asp-action="Index"
                       class="btn btn-primary">
                        Abrir
                    </a>

                </div>
            </div>
        </div>

        <!-- AGENDAMENTOS -->
        <div class="col-md-3">
            <div class="card shadow h-100">
                <div class="card-body text-center">

                    <i class="bi bi-calendar-check text-primary" style="font-size:40px"></i>

                    <h5 class="mt-3">Agendamentos</h5>

                    <p class="text-muted">
                        Controle de atendimentos do PetShop.
                    </p>

                    <button class="btn btn-secondary" disabled>
                        Em breve
                    </button>

                </div>
            </div>
        </div>

    </div>

</div>