@using Microsoft.AspNetCore.Http
@{
    var usuarioLogado = Context.Session.GetString("UsuarioLogado");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PetCare</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PetCare.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/petcare.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />

</head>

<body>

<header>

<nav class="navbar navbar-expand-lg navbar-petcare shadow-sm">

<div class="container">

<a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">

<img src="~/images/petcare-branco.png" width="110" class="me-2" />

</a>

<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu">
<span class="navbar-toggler-icon"></span>
</button>

<div class="collapse navbar-collapse" id="menu">

<ul class="navbar-nav me-auto">

<li class="nav-item">
<a class="nav-link" asp-controller="Home" asp-action="Index">
<i class="bi bi-house"></i> Home
</a>
</li>

<li class="nav-item">
<a class="nav-link" asp-controller="Home" asp-action="Privacy">
<i class="bi bi-shield-lock"></i> Privacy
</a>
</li>

@if (usuarioLogado != null)
{
<li class="nav-item">
<a class="nav-link" asp-controller="Clientes" asp-action="Index">
<i class="bi bi-people"></i> Clientes
</a>
</li>
}

</ul>

@if (usuarioLogado != null)
{
<div class="dropdown">

<button class="btn btn-user dropdown-toggle"
type="button"
data-bs-toggle="dropdown">

<i class="bi bi-person-circle"></i> @usuarioLogado

</button>

<ul class="dropdown-menu dropdown-menu-end">

<li>
<a class="dropdown-item"
asp-controller="UsuariosSistema"
asp-action="Index">

<i class="bi bi-person-plus"></i> Usuários do Sistema
</a>
</li>

<li><hr class="dropdown-divider"></li>

<li>
<a class="dropdown-item text-danger"
asp-controller="Login"
asp-action="Logout">

<i class="bi bi-box-arrow-right"></i> Sair
</a>
</li>

</ul>

</div>
}

</div>

</div>

</nav>

</header>

<div class="container mt-4">

<main role="main" class="pb-3">

@RenderBody()

</main>

</div>

<footer class="footer mt-5 py-3 border-top text-center text-muted">

<div class="container">

&copy; 2026 - PetCare

</div>

</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>