@model PetCare.Models.Cliente

<h2>Editar Cliente</h2>

<form asp-action="Edit">

    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label>Nome</label>
        <input asp-for="Nome" class="form-control" />
    </div>

    <div class="form-group">
        <label>Email</label>
        <input asp-for="Email" class="form-control" />
    </div>

    <div class="form-group">
        <label>Telefone</label>
        <input asp-for="Telefone" class="form-control" />
    </div>

    <div class="form-group">
        <label>Endereço</label>
        <input asp-for="Endereco" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary mt-3">Salvar</button>

</form>

<hr />

<h4>Pets do Cliente</h4>

@if (Model.Pets != null && Model.Pets.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Nome</th>
                <th>Espécie</th>
                <th>Raça</th>
                <th>Idade</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var pet in Model.Pets)
        {
            <tr>
                <td>@pet.Nome</td>
                <td>@pet.Especie</td>
                <td>@(string.IsNullOrEmpty(pet.Raca) ? "-" : pet.Raca)</td>
                <td>@(pet.Idade.HasValue ? pet.Idade + " anos" : "-")</td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">Este cliente ainda não possui pets cadastrados.</p>
}

<a asp-controller="Pet"
   asp-action="Create"
   asp-route-clienteId="@Model.Id"
   class="btn btn-success mt-2">
    + Adicionar Pet
</a>