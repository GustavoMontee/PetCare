@model Pet

<h2>Editar Pet</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label>Nome</label>
        <input asp-for="Nome" class="form-control" />
    </div>

    <div class="form-group">
        <label>Espécie</label>
        <input asp-for="Especie" class="form-control" />
    </div>

    <div class="form-group">
        <label>Raça</label>
        <input asp-for="Raca" class="form-control" />
    </div>

    <div class="form-group">
        <label>Idade</label>
        <input asp-for="Idade" class="form-control" />
    </div>

    <div class="form-group">
        <label>Cliente</label>
        <select asp-for="ClienteId" asp-items="ViewBag.Clientes" class="form-control"></select>
    </div>

    <button type="submit" class="btn btn-primary">Salvar</button>
</form>