@model IEnumerable<PetCare.Models.Pet>

<h2>Pets</h2>

<a asp-action="Create" class="btn btn-primary mb-3">Novo Pet</a>

<table class="table table-striped table-hover">

    <thead class="table-dark">
        <tr>
            <th>Nome</th>
            <th>Espécie</th>
            <th>Raça</th>
            <th>Idade</th>
            <th>Cliente</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.Nome</td>
            <td>@item.Especie</td>
            <td>@item.Raca</td>
            <td>@item.Idade</td>
            <td>@item.Cliente?.Nome</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Excluir</a>
            </td>
        </tr>
}
    </tbody>

</table>