@{
    ViewData["Title"] = "Login";
}

<div class="container d-flex justify-content-center align-items-center" style="height:85vh;">

    <div class="card shadow-lg p-4" style="width:420px;border-radius:15px;">

        <div class="text-center mb-4">
            <img src="~/images/petcare.png" width="110" />
            <p class="text-muted">Acesso ao sistema</p>
        </div>

        <form method="post" asp-action="Index">

            <div class="mb-3">
                <label class="form-label">Email</label>
                <input name="email" class="form-control" placeholder="Digite seu email" required />
            </div>

            <div class="mb-4">
                <label class="form-label">Senha</label>
                <input type="password" name="senha" class="form-control" placeholder="Digite sua senha" required />
            </div>

            <button type="submit" class="btn btn-primary w-100">
                Entrar
            </button>

        </form>

    </div>

</div>