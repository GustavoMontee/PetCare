@model PetCare.Models.Agendamento

@{
    ViewData["Title"] = "Editar Agendamento";
}

<h1>Editar Agendamento</h1>

<hr />

<div class="row">

    <div class="col-md-6">

        <form asp-action="Edit">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger">
            </div>

            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">

                <label asp-for="ClienteId"
                       class="control-label">
                    Cliente
                </label>

                <select asp-for="ClienteId"
                        class="form-control"
                        asp-items="ViewBag.ClienteId">
                </select>

            </div>

            <div class="form-group mb-3">

                <label asp-for="PetId"
                       class="control-label">
                    Pet
                </label>

                <select asp-for="PetId"
                        class="form-control"
                        asp-items="ViewBag.PetId">
                </select>

            </div>

            <div class="form-group mb-3">

                <label asp-for="ServicoId"
                       class="control-label">
                    Serviço
                </label>

                <select asp-for="ServicoId"
                        class="form-control"
                        asp-items="ViewBag.ServicoId">
                </select>

            </div>

            <div class="form-group mb-3">

                <label asp-for="DataHora"
                       class="control-label">
                </label>

                <input asp-for="DataHora"
                       type="datetime-local"
                       class="form-control" />

            </div>

            <div class="form-group mb-3">

                <label asp-for="Observacoes"
                       class="control-label">
                    Observações
                </label>

                <textarea asp-for="Observacoes"
                          class="form-control">
                </textarea>

            </div>

            <button type="submit"
                    class="btn btn-warning">

                Salvar Alterações

            </button>

            <a asp-action="Index"
               class="btn btn-secondary">

                Voltar

            </a>

        </form>

    </div>

</div>

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}